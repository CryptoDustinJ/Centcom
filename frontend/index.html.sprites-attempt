            line-height: 1.4;
        }
        .team-task-item .task-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 6px;
        }
        .team-task-item .task-title {
            font-weight: bold;
            color: #60a5fa;
            flex: 1;
        }
        .team-task-item .task-id {
            font-size: 9px;
            color: #64748b;
            margin-left: 8px;
        }
        .team-task-item .task-description {
            color: #cbd5e1;
            margin-bottom: 6px;
            font-size: 10px;
        }
        .team-task-item .task-meta {
            display: flex;
            gap: 8px;
            font-size: 9px;
            color: #94a3b8;
            margin-bottom: 6px;
            flex-wrap: wrap;
        }
        .team-task-item .task-tag {
            background: #334155;
            padding: 2px 6px;
            border-radius: 3px;
        }
        .team-task-item .task-assignees {
            display: flex;
            gap: 4px;
            margin-bottom: 6px;
            flex-wrap: wrap;
        }
        .assignee-avatar {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #ffd700;
            color: #0b1220;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 8px;
            font-weight: bold;
            border: 1px solid #f59e0b;
        }
        .assignee-avatar.multiple {
            background: #10b981;
            color: white;
            border-color: #059669;
        }
        .multi-assign-control {
            display: flex;
            gap: 6px;
            align-items: center;
            margin-top: 6px;
            padding: 6px;
            background: #0f172a;
            border-radius: 4px;
        }
        .multi-assign-control label {
            font-size: 10px;
            color: #cbd5e1;
        }
        .agent-checkbox {
            width: auto;
            height: auto;
            margin: 0;
        }
        .agent-checkbox-item {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 10px;
            color: #94a3b8;
            cursor: pointer;
        }
        .agent-checkbox-item input {
            cursor: pointer;
        }
        .btn-assign-multi {
            background: #3b82f6;
            color: white;
            border: none;
            padding: 4px 8px;
            font-size: 10px;
            border-radius: 4px;
            cursor: pointer;
            font-family: inherit;
        }
        .btn-assign-multi:hover {
            background: #2563eb;
        }
        .btn-assign-multi:disabled {
            background: #64748b;
            cursor: not-allowed;
        }
        .btn-complete-multi {
            background: #10b981;
            color: white;
            border: none;
            padding: 4px 8px;
            font-size: 10px;
            border-radius: 4px;
            cursor: pointer;
            font-family: inherit;
            margin-top: 4px;
        }
        .btn-complete-multi:hover {
            background: #059669;
        }
        .credit-split-info {
            font-size: 9px;
            color: #fbbf24;
            margin-top: 4px;
        }

        /* === Agent Control Panel (Right Sidebar) === */
        #agent-control-panel {
            position: fixed;
            top: 80px;
            right: 10px;
            width: 300px;
            max-height: calc(100vh - 120px);
            background: #141722;
            border: 4px solid #0e1119;
            z-index: 1000100;
            display: none;
            flex-direction: column;
            overflow: hidden;
            box-shadow: -8px 0 24px rgba(0,0,0,0.45);
        }
        #agent-control-panel.open { display: flex; }
        #agent-panel-header {
            color: #ffd700;
            font-size: 14px;
            font-weight: bold;
            padding: 8px;
            background: #0b1220;
            border-bottom: 2px solid #1f2937;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        #agent-panel-body {
            flex: 1;
            overflow-y: auto;
            padding: 8px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .agent-status-badge {
            background: #1f2937;
            border: 2px solid #334155;
            border-radius: 6px;
            padding: 6px;
            color: #e5e7eb;
            font-size: 11px;
        }
        .agent-status-badge .label {
            color: #94a3b8;
            font-size: 10px;
        }
        .agent-memory-section, .agent-console-section {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .memory-list {
            flex: 1;
            overflow-y: auto;
            max-height: 200px;
            background: #0b1220;
            border: 2px solid #1f2937;
            border-radius: 6px;
            padding: 4px;
        }
        .memory-item {
            padding: 6px;
            border-bottom: 1px solid #1f2937;
            cursor: pointer;
            font-size: 11px;
            color: #cbd5e1;
        }
        .memory-item:hover { background: #1f2937; }
        .memory-item .date {
            color: #64748b;
            font-size: 10px;
        }
        .console-output {
            flex: 1;
            max-height: 150px;
            overflow-y: auto;
            background: #0b1220;
            border: 2px solid #1f2937;
            border-radius: 6px;
            padding: 4px;
            font-family: monospace;
            font-size: 10px;
            color: #a5f3fc;
            white-space: pre-wrap;
            word-break: break-all;
        }
        .agent-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6px;
        }
        .agent-skills-section {
            display: flex;
            flex-direction: column;
            gap: 4px;
            margin-top: 8px;
            padding-top: 8px;
            border-top: 1px solid #1f2937;
        }
        #agent-skills-container {
            max-height: 120px;
            overflow-y: auto;
            background: #0b1220;
            border: 2px solid #1f2937;
            border-radius: 6px;
            padding: 4px;
            font-size: 10px;
        }
        .skill-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 4px 6px;
            margin-bottom: 2px;
            background: #1e3a5f;
            border-radius: 4px;
            color: #cbd5e1;
        }
        .skill-item .skill-name {
            flex: 1;
        }
        .skill-item .skill-remove {
            background: none;
            border: none;
            color: #ef4444;
            font-size: 12px;
            cursor: pointer;
            padding: 0 4px;
        }
        .skill-item .skill-remove:hover {
            color: #f87171;
        }
        .skill-item.disabled {
            opacity: 0.6;
            background: #1f2937;
        }
        .skill-select {
            width: 100%;
            background: #0f172a;
            color: #e5e7eb;
            border: 1px solid #334155;
            border-radius: 4px;
            padding: 4px;
            font-family: inherit;
            font-size: 10px;
            margin-bottom: 4px;
        }
        .skill-add-btn {
            background: #3b82f6;
            color: white;
            border: none;
            padding: 4px 8px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 10px;
            font-family: inherit;
            width: 100%;
        }
        .skill-add-btn:hover {
            background: #2563eb;
        }
        .agent-action-btn {
            background: #1f2937;
            border: 2px solid #334155;
            color: #e5e7eb;
            padding: 8px;
            border-radius: 6px;
            font-size: 11px;
            cursor: pointer;
            font-family: 'ArkPixel', monospace;
        }
        .agent-action-btn:hover { background: #334155; border-color: #475569; }
        .agent-action-btn.primary { background: #2563eb; border-color: #3b82f6; }
        .agent-action-btn.danger { background: #dc2626; border-color: #ef4444; }

        /* === Command Palette === */
        #command-palette-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.7);
            z-index: 1000200;
            display: none;
            justify-content: center;
            padding-top: 15vh;
            backdrop-filter: blur(2px);
        }
        #command-palette-overlay.open { display: flex; }
        #command-palette {
            background: #141722;
            border: 4px solid #0e1119;
            width: 500px;
            max-width: 90vw;
            border-radius: 8px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.7);
            overflow: hidden;
        }
        #command-input {
            width: 100%;
            padding: 12px;
            background: #0b1220;
            border: none;
            border-bottom: 2px solid #1f2937;
            color: #ffd700;
            font-size: 16px;
            font-family: 'ArkPixel', monospace;
            outline: none;
        }
        #command-results {
            max-height: 300px;
            overflow-y: auto;
        }
        .command-suggestion {
            padding: 10px 12px;
            border-bottom: 1px solid #1f2937;
            cursor: pointer;
            color: #e5e7eb;
            font-size: 12px;
        }
        .command-suggestion:hover, .command-suggestion.selected {
            background: #1f2937;
            color: #ffd700;
        }
        .command-suggestion .hint {
            color: #64748b;
            font-size: 10px;
            display: block;
            margin-top: 4px;
        }

        /* === Live Console === */
        #live-console {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 400px;
            height: 280px;
            background: #0b1220;
            border: 4px solid #1f2937;
            border-radius: 8px;
            z-index: 1000150;
            display: none;
            flex-direction: column;
            box-shadow: -8px 0 24px rgba(0,0,0,0.5);
        }
        #live-console.open { display: flex; }
        #console-header {
            background: #141722;
            padding: 8px;
            border-bottom: 2px solid #1f2937;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: move;
            font-size: 12px;
            color: #ffd700;
        }
        #console-body {
            flex: 1;
            overflow-y: auto;
            padding: 6px;
            font-family: monospace;
            font-size: 10px;
            color: #a5f3fc;
            white-space: pre-wrap;
            word-break: break-all;
        }
        .console-entry { margin-bottom: 4px; border-bottom: 1px solid #1f2937; padding-bottom: 2px; }
        .console-entry.error { color: #f87171; }
        .console-entry.agent-Rook { color: #60a5fa; }
        .console-entry.agent-Ralph { color: #34d399; }
        .console-entry.agent-Nova { color: #c084fc; }

        /* === Activity Log / Notifications === */
        #activity-log {
            position: fixed;
            top: 10px;
            right: 10px;
            width: 280px;
            max-height: 200px;
            background: rgba(20, 23, 34, 0.95);
            border: 2px solid #1f2937;
            border-radius: 6px;
            z-index: 1000300;
            overflow-y: auto;
            padding: 6px;
            display: none;
        }
        #activity-log.open { display: block; }
        .activity-item {
            padding: 6px;
            border-bottom: 1px solid #1f2937;
            font-size: 10px;
            color: #e5e7eb;
            animation: fadeIn 0.3s ease;
        }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
        .activity-item.success { border-left: 3px solid #22c55e; }
        .activity-item.error { border-left: 3px solid #ef4444; }
        .activity-item.info { border-left: 3px solid #3b82f6; }

        /* Confetti celebration */
        #confetti-canvas {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            pointer-events: none;
            z-index: 1000400;
        }

        /* Collaboration speech bubbles */
        .collab-bubble {
            position: absolute;
            background: rgba(255,255,255,0.9);
            border: 2px solid #000;
            border-radius: 8px;
            padding: 6px 10px;
            font-size: 10px;
            color: #000;
            pointer-events: none;
            z-index: 1200;
            max-width: 160px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.3);
            animation: fadeInUp 0.3s ease;
        }
        @keyframes fadeInUp { from { opacity:0; transform:translateY(5px); } to { opacity:1; transform:translateY(0); } }

        /* Scrollbar styling for panels */
        #task-list::-webkit-scrollbar, .memory-list::-webkit-scrollbar, .console-output::-webkit-scrollbar, #command-results::-webkit-scrollbar, #activity-log::-webkit-scrollbar {
            width: 8px;
        }
        #task-list::-webkit-scrollbar-thumb, .memory-list::-webkit-scrollbar-thumb, .console-output::-webkit-scrollbar-thumb, #command-results::-webkit-scrollbar-thumb, #activity-log::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 0;
        }
        #task-list::-webkit-scrollbar-track, .memory-list::-webkit-scrollbar-track, .console-output::-webkit-scrollbar-track, #command-results::-webkit-scrollbar-track, #activity-log::-webkit-scrollbar-track {
            background: #0b1220;
        }
    </style>
</head>
<body>
    <!-- 加载遮罩 -->
    <div id="loading-overlay">
        <div id="loading-text">Loading Star’s pixel office...</div>
        <div id="loading-progress-container">
            <div id="loading-progress-bar"></div>
        </div>
    </div>
    
    <div id="main-stage">
        <div id="game-container">
            <div id="game-skeleton"><div class="hint">Entering pixel office...</div></div>
            <div id="status-text">Loading...</div>
        </div>
    
    <!-- 底部面板容器 -->
    <div id="bottom-panels">
        <!-- Live Chat Feed -->
        <div id="chat-feed-panel">
            <div id="chat-feed-title">LIVE CHAT</div>
            <div id="chat-feed-list">
                <div style="color:#6b7280;font-size:11px;text-align:center;padding:20px 0;">Connecting to agents...</div>
            </div>
        </div>

        <!-- 状态控制栏 -->
        <div id="control-bar">
            <div id="control-bar-title">Star's Status</div>
            <div id="control-buttons">
                <button id="btn-state-idle" onclick="setState('idle','Idle')">Idle</button>
                <button id="btn-state-writing" onclick="setState('writing','Working')">Work</button>
                <button id="btn-state-syncing" onclick="setState('syncing','Syncing')">Sync</button>
                <button id="btn-state-error" onclick="setState('error','Error')">Error</button>
                <button id="btn-open-drawer" onclick="toggleAssetDrawer()">Decorate</button>
                <button id="btn-task-board" onclick="toggleTaskBoard()">Tasks</button>
                <button id="btn-command-palette" onclick="toggleCommandPalette()">Cmd</button>
                <button id="btn-live-console" onclick="toggleConsole()">Console</button>
            </div>
        </div>

        <!-- Command Center -->
        <div id="command-center-panel">
            <div id="command-center-title">COMMAND CENTER</div>
            <div class="cmd-section-label">System</div>
            <div class="cmd-grid">
                <button class="cmd-btn" onclick="dispatchCmd('syscheck')">Syscheck</button>
                <button class="cmd-btn" onclick="dispatchCmd('fullcheck')">Fullcheck</button>
                <button class="cmd-btn" onclick="dispatchCmd('self-heal')">Self-heal</button>
                <button class="cmd-btn" onclick="dispatchCmd('restart-both')">Restart</button>
            </div>
            <div class="cmd-section-label">Briefing</div>
            <div class="cmd-grid">
                <button class="cmd-btn" onclick="dispatchCmd('morning-briefing')">Briefing</button>
                <button class="cmd-btn" onclick="dispatchCmd('weather')">Weather</button>
                <button class="cmd-btn" onclick="dispatchCmd('watch-check')">Watchlist</button>
                <button class="cmd-btn" onclick="dispatchCmd('email-list')">Inbox</button>
            </div>
            <div class="cmd-section-label">Content</div>
            <div class="cmd-grid">
                <button class="cmd-btn" onclick="dispatchCmd('story')">Story</button>
                <button class="cmd-btn" onclick="dispatchCmd('wallpaper')">Wallpaper</button>
                <button class="cmd-btn" onclick="dispatchCmd('kb-latest')">KB Latest</button>
                <button class="cmd-btn" onclick="dispatchCmd('storybook-list')">Stories</button>
            </div>
            <div class="cmd-section-label">Search</div>
            <div class="cmd-search-row">
                <input class="cmd-search-input" id="cmd-search-query" placeholder="Search query..." onkeydown="if(event.key==='Enter')dispatchCmd('search',this.value)">
                <button class="cmd-btn" style="width:60px" onclick="dispatchCmd('search',document.getElementById('cmd-search-query').value)">Search</button>
            </div>
            <div id="cmd-status"></div>
        </div>
    </div>
    
    <div id="asset-highlight"></div>
    <div id="room-loading-overlay" aria-live="polite" aria-busy="true">
        <div class="room-loading-inner">
            <div id="room-loading-emoji">🦞</div>
            <div id="room-loading-text">Packing shrimp heads...</div>
        </div>
    </div>

    <div id="asset-drawer-backdrop" onclick="toggleAssetDrawer(false)"></div>
    <aside id="asset-drawer">
        <div id="asset-drawer-header">
            <span>Decorate Room · Asset Sidebar</span>
            <button id="btn-close-drawer" onclick="toggleAssetDrawer(false)">Close</button>
        </div>
        <div id="asset-drawer-body">
            <div id="asset-auth-gate" class="asset-preview-box">
                <div class="asset-preview-title">Enter decoration code</div>
                <div class="asset-toolbar">
                    <input id="asset-pass-input" type="password" placeholder="Enter code" />
                    <button onclick="unlockAssetDrawer()">Verify</button>
                </div>
                <div id="asset-auth-msg" class="asset-sub"></div>
            </div>

            <div id="asset-main-content" style="display:none;">
                <div id="asset-move-panel">
                    <div class="asset-toolbar" id="asset-move-row">
                        <button id="btn-move-house" class="btn-move" onclick="generateRpgBackground()">📦 Move to New Home</button>
                        <button id="btn-back-home" class="btn-home" onclick="restoreHomeBackground()">🐚 Return to Old Home</button>
                    </div>
                    <div class="asset-toolbar" id="asset-broker-row">
                        <button class="btn-broker" onclick="toggleBrokerPanel()">🤝 Find Broker</button>
                        <button id="btn-diy" class="btn-diy" onclick="toggleManualPanel()">🪚 DIY Install</button>
                    </div>
                    <div id="asset-move-result" class="asset-sub" style="margin-top:4px; margin-bottom:6px;"></div>
                    <div id="asset-broker-panel">
                        <div class="asset-sub" style="margin-bottom:6px;">Write your style theme (keeps room structure, only changes visual style)</div>
                        <textarea id="asset-broker-prompt" placeholder="e.g. cyberpunk Tokyo night, neon lights, rainy reflections, blue-purple palette"></textarea>
                        <div class="asset-toolbar" style="margin-top:6px; gap:8px; align-items:center; justify-content:flex-start;">
                            <span id="speed-mode-label" class="asset-sub" style="min-width:62px;">Render Mode</span>
                            <button id="speed-fast-btn" type="button" onclick="setSpeedMode('fast')" style="background:#22c55e;color:#052e16;border-color:#16a34a;">🍌2</button>
                            <button id="speed-quality-btn" type="button" onclick="setSpeedMode('quality')" style="background:#334155;color:#e5e7eb;border-color:#475569;">🍌Pro</button>
                        </div>
                        <details id="asset-gemini-panel" style="margin-top:6px; border:0; border-top:1px solid rgba(148,163,184,.18); border-radius:0; padding:8px 0 0; background:transparent;">
                            <summary id="gemini-panel-summary" style="cursor:pointer; color:#cbd5e1;">🔐 API Settings (collapsible)</summary>
                            <div id="asset-gemini-config" style="display:block; margin-top:6px;">
                                <div id="gemini-config-hint" class="asset-sub" style="margin-bottom:4px;">Optional: Fill your image generation API Key (leave empty for basic functionality)</div>
                                <div class="asset-sub" style="margin-bottom:6px;"><a id="gemini-api-doc-link" href="https://ai.google.dev/gemini-api/docs/api-key?hl=en" target="_blank" rel="noopener noreferrer">📘 How to get a Google API Key</a></div>
                                <div id="gemini-mask-status" class="asset-sub" style="margin-bottom:6px; color:#a7f3d0;"></div>
                                <div class="asset-toolbar" style="gap:6px; flex-wrap:wrap;">
                                    <input id="gemini-api-key-input" type="password" placeholder="Paste GEMINI_API_KEY (input hidden)" style="min-width:220px; flex:1;" autocomplete="new-password" />
                                    <button id="btn-save-gemini-key" onclick="saveGeminiConfigFromUI()">Save Key</button>
                                </div>
                                <div id="gemini-config-msg" class="asset-sub" style="margin-top:4px;"></div>
                            </div>
                        </details>
                        <div id="asset-broker-actions">
                            <button onclick="generateCustomRpgBackground()">Move with broker's plan</button>
                        </div>
                    </div>
                </div>

                <div id="asset-home-actions-panel" class="asset-preview-box" style="margin-bottom:10px;">
                    <div class="asset-toolbar" style="margin-bottom:6px; gap:8px;">
                        <button id="btn-back-last-bg" class="btn-home" onclick="restoreLastGeneratedBackground()">↩️ Return to Previous Home</button>
                        <button id="btn-favorite-home" class="btn-home" onclick="saveCurrentHomeFavorite()">⭐ Favorite this home</button>
                    </div>
                    <details id="asset-home-favorites" style="margin:0;">
                        <summary id="asset-home-favorites-title" class="asset-preview-title">🏠 Favorites</summary>
                        <div id="asset-home-favorites-list" class="home-fav-list"></div>
                    </details>
                </div>

                <div id="asset-manual-panel" style="display:flex; flex-direction:column; flex:1; min-height:0;">
                    <div class="asset-toolbar">
                        <input id="asset-search" placeholder="Search assets (desk / sofa / star)" oninput="renderAssetDrawerList()" />
                    </div>
                    <div id="asset-list"></div>
                    <div id="asset-upload-panel">
                        <input id="asset-upload-file" type="file" accept="image/*" style="display:none;" />
                        <div class="asset-upload-grid" style="margin-top:0; margin-bottom:6px; gap:8px;">
                            <button id="asset-choose-btn" onclick="openInlineAssetUploader()">Upload Assets</button>
                            <button id="asset-commit-refresh-btn" onclick="commitAndRefresh()" disabled style="opacity:.55;">Confirm Refresh</button>
                            <button id="asset-reset-default-btn" onclick="resetSelectedAssetToDefault()" disabled style="opacity:.55;">Reset Default</button>
                            <button id="asset-restore-prev-btn" onclick="restoreSelectedAssetPrev()" disabled style="opacity:.55;">Restore Previous</button>
                        </div>
                        <div id="asset-upload-result" class="asset-sub"></div>
                    </div>
                </div>
            </div>
        </div>
    </aside>
    <div id="coords-overlay" style="display:none; position:fixed; pointer-events:none; background:rgba(0,0,0,0.85); color:#fff; font-family:ArkPixel,monospace; font-size:14px; padding:8px 12px; border-radius:4px; z-index:99999;">
        <div id="coords-display">X: 0 | Y: 0</div>
    </div>
    <button id="coords-toggle" style="position:fixed; top:calc(env(safe-area-inset-top, 0px) + 12px); right:12px; z-index:999999; padding:8px 10px; font-family:ArkPixel,monospace; font-size:13px; cursor:pointer; border:2px solid #333; border-radius:5px; background:#333; color:#fff;">
