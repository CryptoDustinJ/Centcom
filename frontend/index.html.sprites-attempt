        let agentMemoryCache = {};
        let agentConsoleCache = {};

        // Keyboard shortcut: Ctrl+P
        document.addEventListener('keydown', (e) => {
            if ((e.ctrlKey || e.metaKey) && e.key === 'p') {
                e.preventDefault();
                toggleCommandPalette();
            }
            if (e.key === 'Escape') {
                closeAgentPanel();
                hideTaskBoard();
                hideCommandPalette();
                hideConsole();
            }
        });

        // === Task Board ===
        async function loadTaskBoard() {
            const list = document.getElementById('task-list');
            try {
                const resp = await fetch('/soul/goals?t=' + Date.now());
                const data = await resp.json();
                list.innerHTML = '';
                if (data.goals && data.goals.length > 0) {
                    data.goals.forEach(goal => {
                        const item = document.createElement('div');
                        item.className = 'task-item';
                        item.draggable = true;
                        item.innerHTML = `<div class="task-source">From SOUL.md</div>${goal}`;
                        item.ondragstart = (e) => {
                            e.dataTransfer.setData('text/plain', goal);
                            e.dataTransfer.effectAllowed = 'copy';
                        };
                        list.appendChild(item);
                    });
                } else {
                    list.innerHTML = '<div style="padding:10px; color:#64748b; text-align:center;">No tasks found in SOUL.md</div>';
                }
