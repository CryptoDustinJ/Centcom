        function renderTeamTaskItem(task) {
            const item = document.createElement('div');
            item.className = 'team-task-item';
            item.dataset.taskId = task.id;

            // Normalize assignees: backend stores both 'assignees' (array) and 'assignee' (single)
            let assignees = [];
            if (task.assignees && Array.isArray(task.assignees)) {
                assignees = task.assignees;
            } else if (task.assignee) {
                assignees = [{ agent: task.assignee, agentId: task.assignee_id }];
            }

            // Build assignee avatars
            const assigneeAvatars = assignees.map(a => {
                const initials = a.agent ? a.agent.charAt(0).toUpperCase() : '?';
                const isMulti = assignees.length > 1;
                return `<span class="assignee-avatar ${isMulti ? 'multiple' : ''}" title="${a.agent}">${initials}</span>`;
            }).join('');

            // Build tags
            const tags = (task.tags || []).map(t => `<span class="task-tag">${t}</span>`).join('');

            // Room and points
            const meta = [];
            if (task.room) meta.push(`📍 ${task.room}`);
            if (task.points !== undefined) meta.push(`⚡ ${task.points} pts`);
            if (assignees.length > 1) {
                const splitPct = task.credit_split || Math.round(100 / assignees.length);
                meta.push(`👥 ${assignees.length} way (${splitPct}% each)`);
            }
            meta.push(`#${task.id ? task.id.split('_')[1] : '??'}`);

            // Status color
            const statusColors = { open: '#10b981', in_progress: '#f59e0b', completed: '#64748b' };
            const statusColor = statusColors[task.status] || '#94a3b8';

            // Build controls based on task status
            let controlsHtml = '';
            if (task.status === 'open') {
                // Show assignment UI
                controlsHtml = buildAssignmentControl(task.id, assignees);
            } else if (task.status === 'in_progress') {
                // Show complete button - anyone can complete, not just assignees (flexible)
                controlsHtml = `<button class="btn-complete-multi" onclick="completeMultiTask('${task.id}')">✓ Complete Task</button>`;
            } else if (task.status === 'completed') {
                controlsHtml = `<div style="font-size:10px;color:#10b981;">✓ Completed ${task.completed_at ? 'on ' + new Date(task.completed_at).toLocaleDateString() : ''}</div>`;
            }

            item.innerHTML = `
                <div class="task-header">
                    <span class="task-title">${task.title}</span>
                    <span class="task-id" style="color:${statusColor}">${task.status.replace('_', ' ').toUpperCase()}</span>
                </div>
                ${task.description ? `<div class="task-description">${task.description}</div>` : ''}
                <div class="task-meta">${tags}${meta.length ? ' • ' + meta.join(' • ') : ''}</div>
                ${assigneeAvatars ? `<div class="task-assignees">${assigneeAvatars}</div>` : ''}
                <div class="multi-assign-control">
                    ${controlsHtml}
                </div>
            `;

            return item;
        }

