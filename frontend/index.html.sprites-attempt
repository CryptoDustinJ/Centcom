        function filterCommands(query) {
            const results = document.getElementById('command-results');
            results.innerHTML = '';
            const q = query.toLowerCase();
            // Support free-form "tell X to Y" - if starts with "tell", show matching agent commands
            const matches = COMMANDS.filter(c => c.cmd.toLowerCase().includes(q));
            if (matches.length === 0) {
                // If typed "tell X to Y", try to match an agent
                const tellMatch = q.match(/tell\s+(\w+)\s+to/i);
                if (tellMatch) {
                    const agentName = tellMatch[1].charAt(0).toUpperCase() + tellMatch[1].slice(1);
                    const div = document.createElement('div');
                    div.className = 'command-suggestion';
                    div.innerHTML = `tell ${agentName} to ...<span class="hint">Send message to ${agentName}</span>`;
                    div.onclick = () => { sendToAgent(agentName); hideCommandPalette(); };
                    results.appendChild(div);
                    return;
                }
                results.innerHTML = '<div class="command-suggestion">No matches</div>';
                return;
            }
            matches.forEach(m => {
                const div = document.createElement('div');
                div.className = 'command-suggestion';
                div.innerHTML = `${m.cmd}<span class="hint">${m.desc}</span>`;
                div.onclick = () => { m.handler(); hideCommandPalette(); };
                results.appendChild(div);
            });
        }
        document.getElementById('command-input').addEventListener('input', (e) => filterCommands(e.target.value));
        // Enter key to execute first match or free-form tell command
        document.getElementById('command-input').addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                const q = e.target.value.trim().toLowerCase();
                const tellMatch = q.match(/tell\s+(\w+)\s+to\s+(.*)/i);
                if (tellMatch) {
                    const agentName = tellMatch[1].charAt(0).toUpperCase() + tellMatch[1].slice(1);
                    sendToAgent(agentName);
                    hideCommandPalette();
                    return;
                }
                const match = COMMANDS.find(c => c.cmd.toLowerCase().includes(q));
                if (match) { match.handler(); hideCommandPalette(); }
            }
            if (e.key === 'Escape') hideCommandPalette();
        });
