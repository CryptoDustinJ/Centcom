        function sendToAgent(agentName) {
            const input = document.getElementById('command-input');
            const raw = input ? input.value : '';
            // Extract the message after "tell <name> to"
            const match = raw.match(/tell\s+\w+\s+to\s+(.*)/i);
            const msg = match ? match[1].trim() : prompt(`Message to ${agentName}:`);
            if (!msg) return;
            addActivity(`Sending to ${agentName}: ${msg.substring(0, 60)}...`, 'info');
            // Find the agent's ID from the agents list
            fetch('/agents?t=' + Date.now()).then(r => r.json()).then(agents => {
                const agent = agents.find(a => a.name === agentName);
                if (!agent) { addActivity(`Agent ${agentName} not found`, 'error'); return; }
                fetch(`/agents/${agent.agentId}/send-message`, {
                    method: 'POST',
