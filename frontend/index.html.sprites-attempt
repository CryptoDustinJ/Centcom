            try {
                const resp = await fetch(`/agents/${agentId}/assign-task`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ task: task })
                });
                const data = await resp.json();
                if (data.ok) {
                    addActivity(`Task assigned: ${task.substring(0,40)}...`, 'success');
                    celebrate();
                } else {
                    addActivity('Task failed: ' + data.msg, 'error');
                }
            } catch (err) {
                addActivity('Assign task error', 'error');
            }
            hideTaskBoard();
        });

        // === Agent Click Handling ===
        // Add click detection to agents in update loop (in game.js)
        // We'll inject this into the existing game code via a hook
        window.addEventListener('message', (e) => {
            if (e.data === 'openAgentPanel') {
                openAgentPanel(e.detail.agentId);
            }
        });

        // Expose functions globally for onclick handlers
        window.toggleTaskBoard = toggleTaskBoard;
        window.closeAgentPanel = closeAgentPanel;
        window.toggleConsole = toggleConsole;
        window.toggleCommandPalette = toggleCommandPalette;

        // === CM-17: Skill Supply Closet ===
        let allSkillsCache = []; // Cached list of all skills from /skills/list

        async function loadAgentSkills(agentId) {
            const container = document.getElementById('agent-skills-container');
            if (!container) return;

            // Load all skills if not cached
            if (allSkillsCache.length === 0) {
                try {
                    const resp = await fetch('/skills/list?t=' + Date.now());
                    const data = await resp.json();
                    if (data.ok && Array.isArray(data.skills)) {
                        allSkillsCache = data.skills;
                    }
                } catch (err) {
                    console.warn('Failed to load skills list:', err);
                }
            }

            // Load agent's current authorized skills
            let agentSkills = [];
            try {
                const resp = await fetch(`/agents/${agentId}/skills?t=${Date.now()}`);
                const data = await resp.json();
                if (data.ok && Array.isArray(data.skills)) {
                    agentSkills = data.skills;
                }
            } catch (err) {
                console.warn('Failed to load agent skills:', err);
            }

            // Render UI
            container.innerHTML = '';

            if (allSkillsCache.length === 0) {
                container.innerHTML = '<div style="padding:6px; color:#64748b;">No skills available</div>';
                return;
            }

            // Show current skills with remove buttons
            agentSkills.forEach(skillId => {
                const skillInfo = allSkillsCache.find(s => s.id === skillId);
                const skillName = skillInfo ? skillInfo.name : skillId;
                const item = document.createElement('div');
                item.className = 'skill-item';
                item.innerHTML = `
                    <span class="skill-name">${skillName}</span>
                    <button class="skill-remove" onclick="removeAgentSkill('${agentId}', '${skillId}')">✕</button>
                `;
                container.appendChild(item);
            });

            // Add "Add skill" dropdown + button
            const unassigned = allSkillsCache.filter(s => !agentSkills.includes(s.id));
            if (unassigned.length > 0) {
                const addRow = document.createElement('div');
                addRow.style.display = 'flex';
                addRow.style.gap = '4px';
                addRow.innerHTML = `
                    <select id="skill-select-${agentId}" class="skill-select" style="flex:1;">
                        <option value="">Add skill...</option>
                        ${unassigned.map(s => `<option value="${s.id}">${s.name}</option>`).join('')}
                    </select>
                    <button class="skill-add-btn" onclick="addAgentSkill('${agentId}')">Add</button>
                `;
                container.appendChild(addRow);
            }
        }

        window.addAgentSkill = async function(agentId) {
            const select = document.getElementById(`skill-select-${agentId}`);
            if (!select) return;
            const skillId = select.value;
            if (!skillId) return;

            try {
                const resp = await fetch(`/agents/${agentId}/skills`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ skill_id: skillId, action: 'add' })
                });
                const data = await resp.json();
                if (data.ok) {
                    addActivity(`Skill "${skillId}" added to ${agentId}`, 'success');
                    // Refresh skills list
                    await loadAgentSkills(agentId);
                } else {
                    alert('Failed: ' + data.msg);
                }
            } catch (err) {
                alert('Error adding skill');
            }
        };

        window.removeAgentSkill = async function(agentId, skillId) {
            if (!confirm(`Remove skill "${skillId}" from ${agentId}?`)) return;
            try {
                const resp = await fetch(`/agents/${agentId}/skills`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ skill_id: skillId, action: 'remove' })
                });
                const data = await resp.json();
                if (data.ok) {
                    addActivity(`Skill "${skillId}" removed from ${agentId}`, 'info');
                    await loadAgentSkills(agentId);
                } else {
                    alert('Failed: ' + data.msg);
                }
            } catch (err) {
                alert('Error removing skill');
            }
        };
    </script>
